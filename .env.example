# MiniLLMOps Configuration

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Model Settings
DEVICE=cpu # or cuda
MODEL_PATH=models/checkpoints/best_model.pt
VOCAB_PATH=models/vocab.json

# Training Settings
BATCH_SIZE=32
BLOCK_SIZE=64
LEARNING_RATE=3e-4
MAX_ITERS=5000
EVAL_INTERVAL=500
EVAL_ITERS=200

# MLflow Settings
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=mini-llmops

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_METRICS_PATH=/metrics
